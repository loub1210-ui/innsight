# ────────────────────────────────────────────────────────────────────────
# Supabase — récupère ces valeurs dans ton projet Supabase > Settings > API
# ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optionnel — pour Server Actions et Supabase Storage
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ────────────────────────────────────────────────────────────────────────
# Clé de chiffrement maître (OBLIGATOIRE pour la table api_integrations)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Ne jamais exposer ni partager. Si perdue, toutes les clés stockées deviennent illisibles.
# ────────────────────────────────────────────────────────────────────────
APP_ENCRYPTION_KEY=remplacer_par_64_caracteres_hex

# ────────────────────────────────────────────────────────────────────────
# Fallback environnement (optionnel) — utilisé si la clé n'est pas configurée
# depuis la page Settings. Format : <SERVICE>_API_KEY
# ────────────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# PAPPERS_API_KEY=...
